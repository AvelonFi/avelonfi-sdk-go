# AidosFi Go SDK — Environment Variables
# Copy this to .env and fill in your values.

# Required: Your AidosFi API key (starts with sk_liv_ or sk_test_)
AIDOSFI_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override API base URL (default: https://api.avelonfi.xyz)
# AIDOSFI_BASE_URL=https://api.avelonfi.xyz

# Optional: Override WebSocket URL (default: wss://ws.avelonfi.xyz)
# AIDOSFI_WS_URL=wss://ws.avelonfi.xyz

# Optional: Request timeout in milliseconds (default: 30000)
# AIDOSFI_TIMEOUT=30000
